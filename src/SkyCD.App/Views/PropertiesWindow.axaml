<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SkyCD.Presentation.ViewModels;assembly=SkyCD.Presentation"
        xmlns:cc="clr-namespace:SkyCD.UI.Controls;assembly=SkyCD.UI"
        xmlns:converters="clr-namespace:SkyCD.App.Converters"
        xmlns:loc="clr-namespace:SkyCD.App.Localization"
        x:Class="SkyCD.App.Views.PropertiesWindow"
        x:DataType="vm:PropertiesDialogViewModel"
        Width="411"
        Height="426"
        MinWidth="411"
        MinHeight="426"
        MaxWidth="411"
        MaxHeight="426"
        CanResize="False"
        CanMinimize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/skycd.ico"
        Title="{loc:Loc Key=window.properties.title}">

    <Window.Resources>
        <converters:IconGlyphConverter x:Key="IconConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="*,Auto" Margin="0">
        <TabControl Margin="8,8,8,0" SelectedIndex="0" TabStripPlacement="Top">
            <TabItem Header="{loc:Loc Key=window.properties.general}">
                <Grid Margin="10,8,10,10" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="32,8,*">
                    <Border Width="32"
                            Height="32"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Top"
                            CornerRadius="2">
                        <Image Width="24" Height="24" Source="{Binding IconGlyph, Converter={StaticResource IconConverter}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Column="2" Text="{loc:Loc Key=window.properties.name}" VerticalAlignment="Top"/>
                    <TextBox Grid.Column="2"
                             Grid.Row="1"
                             Margin="0,2,0,0"
                             Text="{Binding Name}"/>

                    <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Margin="0,12,0,4" Text="{loc:Loc Key=window.properties.comments}" VerticalAlignment="Top"/>
                    <TextBox Grid.Row="3"
                             Grid.ColumnSpan="3"
                             Margin="0,0,0,0"
                             Text="{Binding Comments}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>
            <TabItem Header="{loc:Loc Key=window.properties.properties}" IsVisible="{Binding HasInfoTab}">
                <cc:PropertiesList Margin="8,8,8,10"
                                   PropertiesData="{Binding InfoProperties}"
                                   PropertyHeader="{loc:Loc Key=window.properties.property_header}"
                                   ValueHeader="{loc:Loc Key=window.properties.value_header}"/>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1"
              HorizontalAlignment="Right"
              Margin="0,10,12,10"
              ColumnDefinitions="Auto,Auto"
              ColumnSpacing="6">
            <Button Grid.Column="0"
                    Content="{loc:Loc Key=common.ok}"
                    MinWidth="74"
                    Padding="10,4"
                    IsDefault="True"
                    Command="{Binding ConfirmCommand}"/>
            <Button Grid.Column="1"
                    Content="{loc:Loc Key=common.cancel}"
                    MinWidth="74"
                    Padding="10,4"
                    IsCancel="True"
                    Click="OnCancelClicked"/>
        </Grid>
    </Grid>
</Window>
