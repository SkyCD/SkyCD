<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SkyCD.Presentation.ViewModels;assembly=SkyCD.Presentation"
        x:Class="SkyCD.App.Views.OptionsWindow"
        x:DataType="vm:OptionsDialogViewModel"
        Width="760"
        Height="520"
        MinWidth="700"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        CanMinimize="False"
        Icon="/Assets/skycd.ico"
        Title="Options">

    <Design.DataContext>
        <vm:OptionsDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="14,10,14,8">
            <TextBlock Text="Settings"
                       FontSize="18"
                       FontWeight="SemiBold"/>
        </Border>

        <Grid Grid.Row="1"
              Margin="14,10,14,10"
              ColumnDefinitions="250,*"
              ColumnSpacing="14">
            <Border BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Grid.RowSpan="2">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                    <TextBox PlaceholderText="Search"
                             Text="{Binding SettingsSearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding FilteredSettingCategories}"
                             SelectedItem="{Binding SelectedSettingCategory}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="8,5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Foreground="#8C8C8C"
                               FontSize="11"
                               Text="Use arrows to navigate categories"/>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
                      RowSpacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold">
                        <Run Text="Tools"/>
                        <Run Text="  >  "/>
                        <Run Text="{Binding CurrentCategoryName}"/>
                    </TextBlock>

                    <StackPanel Grid.Row="1"
                                IsVisible="{Binding ShowPluginPathSection}"
                                Spacing="8">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Text="Project Settings" FontSize="15"/>
                            <Border Grid.Column="1" Height="1" Background="#2E2E2E" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="10">
                            <TextBlock Text="Plug-in path:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PluginPath}"/>
                            <Button Grid.Column="2"
                                    Content="Browse..."
                                    MinWidth="90"
                                    Command="{Binding BrowsePluginPathCommand}"/>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="2"
                          IsVisible="{Binding ShowPluginListSection}"
                          RowDefinitions="Auto,Auto,*"
                          RowSpacing="8">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Text="Plug-ins" FontSize="15"/>
                            <Border Grid.Column="1" Height="1" Background="#2E2E2E" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <TextBox Width="260"
                                     PlaceholderText="Type to filter installed plugins"/>
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="#8C8C8C"
                                       Text="{Binding InfoMessage}"/>
                        </Grid>
                        <Border Grid.Row="2"
                                BorderBrush="#2E2E2E"
                                BorderThickness="1">
                            <Grid ColumnDefinitions="2*,3*">
                                <Border BorderBrush="#2E2E2E" BorderThickness="0,0,1,0">
                                    <Grid RowDefinitions="Auto,*">
                                        <Border BorderBrush="#2E2E2E" BorderThickness="0,0,0,1" Padding="8,6">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <TextBlock Text="On" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="Installed" FontWeight="SemiBold"/>
                                            </Grid>
                                        </Border>
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding Plugins}"
                                                 SelectedItem="{Binding SelectedPlugin}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:OptionsPluginItem">
                                                    <Border BorderBrush="#2E2E2E" BorderThickness="0,0,0,1" Padding="8,6">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                            <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                            <StackPanel Grid.Column="1" Spacing="2">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Type}" Foreground="#9CA3AF" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="10" Margin="12">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding SelectedPlugin.Name}" FontSize="18" FontWeight="SemiBold"/>
                                        <Button Content="{Binding SelectedPlugin.Type}"
                                                Foreground="#9CA3AF"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalAlignment="Left"
                                                Command="{Binding OpenSelectedPluginAuthorUrlCommand}"/>
                                        <TextBlock Text="{Binding SelectedPlugin.ExtendedInfo}" Foreground="#8C8C8C" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <Button Content="Refresh"
                                                MinWidth="90"
                                                Command="{Binding RefreshPluginsCommand}"/>
                                        <Button Content="Configure"
                                                MinWidth="90"
                                                Command="{Binding ConfigurePluginCommand}"/>
                                    </StackPanel>
                                    <Border Grid.Row="2"
                                            BorderBrush="#2E2E2E"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10">
                                        <TextBlock Text="{Binding InfoMessage}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#CFCFCF"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                IsVisible="False"
                                Spacing="6">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Text="Actions" FontSize="15"/>
                            <Border Grid.Column="1" Height="1" Background="#2E2E2E" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Refresh"
                                    MinWidth="90"
                                    Command="{Binding RefreshPluginsCommand}"/>
                            <Button Content="Configure"
                                    MinWidth="90"
                                    Command="{Binding ConfigurePluginCommand}"/>
                        </StackPanel>
                        <TextBlock IsVisible="{Binding ShowPluginInfoSection}"
                                   Text="{Binding InfoMessage}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                IsVisible="{Binding ShowLanguageSection}"
                                Spacing="8">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Text="Application Settings" FontSize="15"/>
                            <Border Grid.Column="1" Height="1" Background="#2E2E2E" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*" ColumnSpacing="10">
                            <TextBlock Text="Language:" VerticalAlignment="Top"/>
                            <ListBox Grid.Column="1"
                                     ItemsSource="{Binding Languages}"
                                     SelectedItem="{Binding SelectedLanguage}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LanguageItem">
                                        <TextBlock Text="{Binding DisplayText}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="4"
                            IsVisible="{Binding ShowNoSearchResults}"
                            BorderBrush="#6A5C2D"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                        <TextBlock Text="No settings match the current search."
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Save"
                        MinWidth="90"
                        IsDefault="True"
                        Command="{Binding ConfirmCommand}"/>
                <Button Content="Cancel"
                        MinWidth="90"
                        IsCancel="True"
                        Click="OnCancelClicked"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

