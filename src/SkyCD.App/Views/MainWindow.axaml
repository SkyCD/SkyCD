<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SkyCD.Presentation.ViewModels;assembly=SkyCD.Presentation"
        xmlns:cc="clr-namespace:SkyCD.UI.Controls;assembly=SkyCD.UI"
        xmlns:converters="clr-namespace:SkyCD.App.Converters"
        xmlns:loc="clr-namespace:SkyCD.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SkyCD.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/skycd.ico"
        MinWidth="700"
        MinHeight="450"
        Title="{loc:Loc Key=window.main.title}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <converters:IconGlyphConverter x:Key="IconConverter"/>
        <ContextMenu x:Key="BrowserContextMenu">
            <MenuItem Header="{loc:Loc Key=menu.expand}" Command="{Binding ExpandSelectionCommand}" CommandParameter="list"/>
            <MenuItem Header="{loc:Loc Key=menu.collapse}" Command="{Binding CollapseSelectionCommand}" CommandParameter="list"/>
            <Separator/>
            <MenuItem Header="{loc:Loc Key=menu.view}">
                <MenuItem Header="{loc:Loc Key=menu.small_icons}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="SmallIcons"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsSmallIconsViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.large_icons}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="LargeIcons"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsLargeIconsViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.list}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="List"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsListViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.details}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="Details"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsDetailsViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.tiles}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="Tiles"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsTilesViewChecked}"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="{loc:Loc Key=menu.arrange_icons_by}">
                <MenuItem Header="{loc:Loc Key=menu.name}"
                          Command="{Binding SetSortModeCommand}"
                          CommandParameter="Name"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsSortByNameChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.type}"
                          Command="{Binding SetSortModeCommand}"
                          CommandParameter="Type"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsSortByTypeChecked}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc Key=menu.refresh}" Command="{Binding RefreshCommand}"/>
            <Separator/>
            <MenuItem Header="{loc:Loc Key=menu.add}" Command="{Binding AddItemCommand}"/>
            <MenuItem Header="{loc:Loc Key=menu.delete}" Command="{Binding DeleteItemCommand}"/>
            <Separator/>
            <MenuItem Header="{loc:Loc Key=menu.properties}" Command="{Binding OpenPropertiesCommand}"/>
        </ContextMenu>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{loc:Loc Key=menu.file}">
                <MenuItem Header="{loc:Loc Key=menu.new}" HotKey="Ctrl+N" Command="{Binding NewCatalogCommand}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.open}" HotKey="Ctrl+O" Command="{Binding OpenCatalogCommand}"/>
                <MenuItem Header="{loc:Loc Key=menu.save}" HotKey="Ctrl+S" Command="{Binding SaveCatalogCommand}"/>
                <MenuItem Header="{loc:Loc Key=menu.save_as}" HotKey="F12" Command="{Binding SaveCatalogAsCommand}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.properties}" Command="{Binding OpenPropertiesCommand}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.exit}" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc Key=menu.edit}">
                <MenuItem Header="{loc:Loc Key=menu.add}" HotKey="F2" Command="{Binding AddItemCommand}"/>
                <MenuItem Header="{loc:Loc Key=menu.delete}" HotKey="Delete" Command="{Binding DeleteItemCommand}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.properties}" HotKey="Alt+Enter" Command="{Binding OpenPropertiesCommand}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc Key=menu.view}">
                <MenuItem Header="{loc:Loc Key=menu.status_bar}"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsStatusBarVisible}"
                          Command="{Binding ToggleStatusBarCommand}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.tiles}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="Tiles"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsTilesViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.small_icons}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="SmallIcons"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsSmallIconsViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.large_icons}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="LargeIcons"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsLargeIconsViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.list}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="List"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsListViewChecked}"/>
                <MenuItem Header="{loc:Loc Key=menu.details}"
                          Command="{Binding SetViewModeCommand}"
                          CommandParameter="Details"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsDetailsViewChecked}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.arrange_icons_by}">
                    <MenuItem Header="{loc:Loc Key=menu.name}"
                              Command="{Binding SetSortModeCommand}"
                              CommandParameter="Name"
                              ToggleType="CheckBox"
                              IsChecked="{Binding IsSortByNameChecked}"/>
                    <MenuItem Header="{loc:Loc Key=menu.type}"
                              Command="{Binding SetSortModeCommand}"
                              CommandParameter="Type"
                              ToggleType="CheckBox"
                              IsChecked="{Binding IsSortByTypeChecked}"/>
                    <MenuItem Header="{loc:Loc Key=menu.size}"
                              Command="{Binding SetSortModeCommand}"
                              CommandParameter="Size"
                              ToggleType="CheckBox"
                              IsChecked="{Binding IsSortBySizeChecked}"/>
                </MenuItem>
                <MenuItem Header="{loc:Loc Key=menu.refresh}" HotKey="F5" Command="{Binding RefreshCommand}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc Key=menu.tools}">
                <MenuItem Header="{loc:Loc Key=menu.options}" HotKey="Ctrl+Alt+O" Command="{Binding OpenOptionsCommand}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc Key=menu.help}">
                <MenuItem Header="{loc:Loc Key=menu.project_sourceforge}" Command="{Binding OpenProjectWebsiteCommand}"/>
                <MenuItem Header="{loc:Loc Key=menu.project_github}" Command="{Binding OpenGithubAreaCommand}"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Key=menu.about}" Command="{Binding OpenAboutCommand}"/>
            </MenuItem>
        </Menu>

        <cc:ClassicToolbar DockPanel.Dock="Top">
            <cc:ClassicToolbar.Items>
                <cc:ClassicToolbarButton MinWidth="68" Padding="8,3" Command="{Binding NewCatalogCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Image Width="16" Height="16" Source="/Assets/add-from-media.png"/>
                        <TextBlock Text="{loc:Loc Key=toolbar.new}"/>
                    </StackPanel>
                </cc:ClassicToolbarButton>
                <cc:ClassicToolbarButton MinWidth="68" Padding="8,3" Command="{Binding OpenCatalogCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Image Width="16" Height="16" Source="/Assets/add-from-folder.png"/>
                        <TextBlock Text="{loc:Loc Key=toolbar.open}"/>
                    </StackPanel>
                </cc:ClassicToolbarButton>
                <cc:ClassicToolbarButton MinWidth="68" Padding="8,3" Command="{Binding SaveCatalogCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Image Width="16" Height="16" Source="/Assets/add-from-internet.png"/>
                        <TextBlock Text="{loc:Loc Key=toolbar.save}"/>
                    </StackPanel>
                </cc:ClassicToolbarButton>
            </cc:ClassicToolbar.Items>
        </cc:ClassicToolbar>

        <Border DockPanel.Dock="Bottom"
                IsVisible="{Binding IsStatusBarVisible}"
                BorderBrush="#D4D4D4"
                BorderThickness="1,1,0,0"
                Padding="8,4">
            <Grid ColumnDefinitions="*,Auto,120" ColumnSpacing="10">
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressText}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsProgressVisible}"/>
                <ProgressBar Grid.Column="2"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"
                             IsVisible="{Binding IsProgressVisible}"/>
            </Grid>
        </Border>

        <Grid x:Name="MainLayoutGrid" RowDefinitions="*">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TreeView Grid.Column="0"
                      MinWidth="160"
                      ItemsSource="{Binding TreeNodes}"
                      SelectedItem="{Binding SelectedTreeNode}"
                      ContextRequested="OnTreeContextRequested">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="vm:BrowserTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate x:DataType="vm:BrowserTreeNode" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Width="16" Height="16" Source="{Binding IconGlyph, Converter={StaticResource IconConverter}}"/>
                            <TextBlock Text="{Binding Title}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{loc:Loc Key=menu.expand}" Command="{Binding ExpandSelectionCommand}" CommandParameter="tree"/>
                        <MenuItem Header="{loc:Loc Key=menu.collapse}" Command="{Binding CollapseSelectionCommand}" CommandParameter="tree"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Key=menu.view}">
                            <MenuItem Header="{loc:Loc Key=menu.small_icons}"
                                      Command="{Binding SetViewModeCommand}"
                                      CommandParameter="SmallIcons"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsSmallIconsViewChecked}"/>
                            <MenuItem Header="{loc:Loc Key=menu.large_icons}"
                                      Command="{Binding SetViewModeCommand}"
                                      CommandParameter="LargeIcons"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsLargeIconsViewChecked}"/>
                            <MenuItem Header="{loc:Loc Key=menu.list}"
                                      Command="{Binding SetViewModeCommand}"
                                      CommandParameter="List"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsListViewChecked}"/>
                            <MenuItem Header="{loc:Loc Key=menu.details}"
                                      Command="{Binding SetViewModeCommand}"
                                      CommandParameter="Details"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsDetailsViewChecked}"/>
                            <MenuItem Header="{loc:Loc Key=menu.tiles}"
                                      Command="{Binding SetViewModeCommand}"
                                      CommandParameter="Tiles"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsTilesViewChecked}"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Key=menu.arrange_icons_by}">
                            <MenuItem Header="{loc:Loc Key=menu.name}"
                                      Command="{Binding SetSortModeCommand}"
                                      CommandParameter="Name"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsSortByNameChecked}"/>
                            <MenuItem Header="{loc:Loc Key=menu.type}"
                                      Command="{Binding SetSortModeCommand}"
                                      CommandParameter="Type"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsSortByTypeChecked}"/>
                            <MenuItem Header="{loc:Loc Key=menu.size}"
                                      Command="{Binding SetSortModeCommand}"
                                      CommandParameter="Size"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding IsSortBySizeChecked}"/>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc Key=menu.refresh}" Command="{Binding RefreshCommand}"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Key=menu.add}" Command="{Binding AddItemCommand}"/>
                        <MenuItem Header="{loc:Loc Key=menu.delete}" Command="{Binding DeleteItemCommand}"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Key=menu.copy}" HotKey="Ctrl+C" Command="{Binding CopyCommand}"/>
                        <MenuItem Header="{loc:Loc Key=menu.paste}" HotKey="Ctrl+V" Command="{Binding PasteCommand}"/>
                        <MenuItem Header="{loc:Loc Key=menu.cut}" HotKey="Ctrl+X" Command="{Binding CutCommand}"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Key=menu.properties}" Command="{Binding OpenPropertiesCommand}"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          ResizeDirection="Columns"
                          Background="#CFCFCF"
                          ShowsPreview="True"/>

            <!-- Details View: tabular list with column headers -->
            <cc:DetailsListView Grid.Column="2"
                                IsVisible="{Binding IsDetailsMode}"
                                ListMinWidth="240"
                                ItemsSource="{Binding BrowserItems}"
                                SelectedItem="{Binding SelectedBrowserItem}"
                                ContextRequested="OnBrowserContextRequested"
                                ListContextMenu="{DynamicResource BrowserContextMenu}"
                                DoubleTapped="OnBrowserListDoubleTapped">
                <cc:DetailsListView.HeaderContent>
                    <Border BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{DynamicResource ThemeControlMidBrush}"
                            Padding="4,2">
                        <Grid ColumnDefinitions="24,*,150,120">
                            <TextBlock Text="" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{loc:Loc Key=details.header.name}" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="{loc:Loc Key=details.header.type}" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="{loc:Loc Key=details.header.size}" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </cc:DetailsListView.HeaderContent>
                <cc:DetailsListView.RowTemplate>
                    <DataTemplate x:DataType="vm:BrowserItem">
                        <Grid ColumnDefinitions="24,*,150,120" Margin="4,2">
                            <Image Width="16" Height="16" Source="{Binding IconGlyph, Converter={StaticResource IconConverter}}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Type}"/>
                            <TextBlock Grid.Column="3" Text="{Binding Size}" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </cc:DetailsListView.RowTemplate>
            </cc:DetailsListView>

            <!-- List View: wrapping simple icon+name layout -->
            <ListBox Grid.Column="2"
                     MinWidth="240"
                     IsVisible="{Binding IsListMode}"
                     ItemsSource="{Binding BrowserItems}"
                     SelectedItem="{Binding SelectedBrowserItem}"
                     ContextRequested="OnBrowserContextRequested"
                     ContextMenu="{DynamicResource BrowserContextMenu}"
                     DoubleTapped="OnBrowserListDoubleTapped">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,2">
                            <Image Width="14" Height="14" Source="{Binding IconGlyph, Converter={StaticResource IconConverter}}"/>
                            <TextBlock Text="{Binding Name}" FontSize="13"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Icon Grid View: Tiles / Small Icons / Large Icons -->
            <ListBox Grid.Column="2"
                     MinWidth="240"
                     IsVisible="{Binding IsIconGridMode}"
                     ItemsSource="{Binding BrowserItems}"
                     SelectedItem="{Binding SelectedBrowserItem}"
                     ContextRequested="OnBrowserContextRequested"
                     ContextMenu="{DynamicResource BrowserContextMenu}"
                     DoubleTapped="OnBrowserListDoubleTapped">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="{Binding $parent[Window].DataContext.BrowserGridItemWidth}"
                                Height="{Binding $parent[Window].DataContext.BrowserGridItemHeight}"
                                Margin="6"
                                Padding="8"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <Image Width="32" Height="32" Source="{Binding IconGlyph, Converter={StaticResource IconConverter}}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" TextAlignment="Center" TextWrapping="Wrap"/>
                                <StackPanel Margin="0,4,0,0"
                                            IsVisible="{Binding $parent[Window].DataContext.IsTilesMode}">
                                    <TextBlock Text="{Binding Type}" HorizontalAlignment="Center" FontSize="12"/>
                                    <TextBlock Text="{Binding Size}" HorizontalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>

</Window>
