<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="clr-namespace:SkyCD.UI.Controls;assembly=SkyCD.UI">
    <Style Selector="cc|ClassicToolbarButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="2,1" />
    </Style>
    <Style Selector="cc|ClassicToolbarButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource ThemeBorderMidBrush}" />
    </Style>
    <Style Selector="cc|ClassicToolbarButton:pressed">
        <Setter Property="Background" Value="{DynamicResource ThemeBorderHighBrush}" />
    </Style>
    <Style Selector="cc|ClassicToolbarButton:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>
</Styles>