<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:SkyCD.Views"
        xmlns:models="using:SkyCD.Models.SystemInfo"
        xmlns:converters="using:SkyCD.Converters"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="360"
        x:Class="SkyCD.Views.AboutWindow"
        x:DataType="views:AboutWindow"
        Width="480" Height="360"
        Title="About SkyCD"
        Icon="/Assets/avalonia-logo.ico"
        CanMaximize="False"
        CanMinimize="False"
        CanResize="False">

  <Window.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
    </Style>
  </Window.Styles>

  <DockPanel Margin="8" LastChildFill="True">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">           
            <TextBlock Text="SkyCD" FontSize="21" FontWeight="Bold" />
            <TextBlock Text="{Binding Version}" FontSize="12" VerticalAlignment="Bottom" Padding="0,0,0,3" />
        </StackPanel>
    </StackPanel>

    <StackPanel Margin="8" Spacing="6" Height="32" DockPanel.Dock="Bottom" Name="BottomButtonBar">
    <Button HorizontalAlignment="Right" Width="80" Margin="0,8,0,0" Click="OnCloseClicked">Close</Button>
          </StackPanel>

    <TabControl Name="MainTabs">
      <TabItem Header="System info" FontSize="14">
        <Grid Margin="8">
            <StackPanel Spacing="10">

              <StackPanel>
                <TextBlock Text="CPU" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                  <ProgressBar Minimum="0" Maximum="100" Value="{Binding CpuPercent}" Height="10" Width="220" />
                  <TextBlock Text="{Binding CpuUsage}" Foreground="#333" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>

              <StackPanel>
                <TextBlock Text="Memory" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                  <ProgressBar Minimum="0" Maximum="100" Value="{Binding MemoryPercent}" Height="10" Width="220" />
                  <StackPanel>
                    <TextBlock Text="{Binding WorkingSet}" Foreground="#333" />
                    <TextBlock Text="{Binding ManagedHeap}" FontSize="11" Foreground="#666" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>

              <Grid ColumnDefinitions="*,*" Margin="0,4,0,0" RowSpacing="0">
                <Border Grid.Column="0" Background="#FFFFFFFF" CornerRadius="6" Padding="8" BorderBrush="#FFE6E9EE" BorderThickness="1" Margin="0,0,8,0">
                  <StackPanel>
                    <TextBlock Text="Threads" FontWeight="SemiBold" FontSize="12" Foreground="#333" />
                    <TextBlock Text="{Binding ThreadInfo}" FontSize="20" FontWeight="Bold" Foreground="#111" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFFFF" CornerRadius="6" Padding="8" BorderBrush="#FFE6E9EE" BorderThickness="1" Margin="8,0,0,0">
                  <StackPanel>
                    <TextBlock Text="Uptime" FontWeight="SemiBold" FontSize="12" Foreground="#333" />
                    <TextBlock Text="{Binding UptimeFriendly}" FontSize="20" FontWeight="Bold" Foreground="#111" />
                    <TextBlock Text="{Binding StartTime}" FontSize="11" Foreground="#666" />
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
        </Grid>
      </TabItem>
      <TabItem Header="Loaded assemblies" FontSize="14">
        <Grid Name="UsedAsemblies">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>


          <!-- Header is sticky vertically; outer ScrollViewer handles horizontal scrolling, inner handles vertical scrolling -->
              <!-- Header removed -->

              <!-- List occupies available space; ListBox provides its own scrolling (vertical scrollbar visible to avoid width shift) -->
              <ListBox Grid.Row="1" ItemsSource="{Binding LoadedAssemblies}" SelectionMode="Multiple" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0"
                       ScrollViewer.VerticalScrollBarVisibility="Visible"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.AllowAutoHide="False"
                       >
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Height" Value="72" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Top" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1" Padding="6">
                      <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large icon on the left -->
                        <Image Grid.Column="0" Source="/Assets/avalonia-logo.ico" Width="48" Height="48" Margin="0,0,8,0" VerticalAlignment="Top" />

                        <!-- Assembly info: name/version on first row; copyright on second row; repository URL on third row -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                          <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1" Margin="0,0,8,0" />
                            <!-- Reserve space for version so it remains visible; name will be truncated with ellipsis if needed -->
                            <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="14" VerticalAlignment="Center" MinWidth="72" TextAlignment="Right" Foreground="#666" />
                          </Grid>

                          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Copyright}" FontSize="12" Foreground="#666" IsVisible="{Binding Copyright}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                          </StackPanel>

                          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                            <TextBlock Text="{Binding RepositoryUrl}" FontSize="12" Foreground="#007ACC" TextDecorations="Underline" IsVisible="{Binding RepositoryUrl}" PointerPressed="OnOpenRepositoryUrl" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                          </StackPanel>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
        </Grid>
      </TabItem>
      <TabItem Header="Project license" FontSize="14" IsSelected="True">
        <Grid Margin="8" RowDefinitions="Auto,*">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Visible"  Grid.Row="1" Padding="0, 0, 2, 0" AllowAutoHide="False">
				<ContentControl Content="{Binding LicenseText}" Background="Transparent" />
            </ScrollViewer>          
        </Grid>
      </TabItem>
    </TabControl>
  </DockPanel>

</Window>